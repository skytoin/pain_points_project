# Copy this file to .env and fill in real values.
# .env is git-ignored; .env.example is committed.

# ====================================================================
# LLM (required)
# ====================================================================
ANTHROPIC_API_KEY=sk-ant-...

# ====================================================================
# Source APIs — fill in only the ones you actually use
# ====================================================================

# Reddit (via praw) — create at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=discovery-pipeline/0.1 by your_username

# Google (YouTube Data API, Google Places)
GOOGLE_API_KEY=

# Yelp Fusion
YELP_API_KEY=

# Apollo.io
APOLLO_API_KEY=

# Apify (scrapers as a service)
APIFY_TOKEN=

# Hunter.io (email finding)
HUNTER_API_KEY=

# NewsAPI
NEWSAPI_KEY=

# Listen Notes (podcasts)
LISTEN_NOTES_API_KEY=

# OpenCorporates
OPENCORPORATES_API_KEY=

# Product Hunt (GraphQL)
PRODUCT_HUNT_TOKEN=

# TheirStack (tech stack lookup by domain)
THEIRSTACK_API_KEY=

# Adzuna (job postings)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ====================================================================
# Runtime config
# ====================================================================

# Path to the SQLite database file (relative to project root)
DATABASE_URL=sqlite+aiosqlite:///data/discovery.db

# Where to store the LLM disk cache
LLM_CACHE_DIR=.diskcache/llm

# Logging
LOG_LEVEL=INFO

# Optional: Sentry for error tracking
# SENTRY_DSN=
